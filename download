import { useEffect, useState } from "react";
import { auth, db } from "../firebase";
import { onAuthStateChanged, signOut, User } from "firebase/auth";
import { doc, getDoc, onSnapshot } from "firebase/firestore";
import { motion } from "framer-motion";
import { 
  LogOut, 
  Play, 
  Lock, 
  Brain, 
  Target, 
  Cpu, 
  User as UserIcon,
  Loader2,
  ChevronRight
} from "lucide-react";
import { Link, useNavigate } from "react-router-dom";
import { useTranslation } from "react-i18next";
import { useAuth } from "../hooks/useAuth";

interface UserProfile {
  hasAccessPsychology?: boolean;
  hasAccessCameleon?: boolean;
  hasAccessAlgo?: boolean;
  isAlgoUser?: boolean;
  isSniper?: boolean;
  matricule?: string;
  whatsappLink?: string;
  zoomLink?: string;
  displayName?: string;
  email?: string;
  role?: string;
}

export default function MemberArea() {
  const { t } = useTranslation();
  const navigate = useNavigate();
  const { user, isAdmin, loading: authLoading } = useAuth();
  const [profile, setProfile] = useState<UserProfile | null>(null);
  const [loading, setLoading] = useState(true);
  const [resumeLoading, setResumeLoading] = useState<string | null>(null);
  const [statusMessage, setStatusMessage] = useState<{ type: "success" | "error", text: string } | null>(null);

  useEffect(() => {
    if (!authLoading && !user) {
      navigate("/login");
    }
  }, [user, authLoading, navigate]);

  useEffect(() => {
    if (user) {
      const docRef = doc(db, "users", user.uid);
      const unsubscribe = onSnapshot(docRef, (docSnap) => {
        if (docSnap.exists()) {
          setProfile(docSnap.data() as UserProfile);
        }
        setLoading(false);
      });
      return () => unsubscribe();
    }
  }, [user]);

  const handleLogout = async () => {
    await signOut(auth);
    navigate("/");
  };

  const handleResume = async (productId: string) => {
    if (!user) return;
    
    try {
      setResumeLoading(productId);
      setStatusMessage(null);
      
      const response = await fetch("/api/generate-token", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
        },
        body: JSON.stringify({
          userId: user.uid,
          productId: productId
        }),
      });

      const data = await response.json();
      if (data.success && data.token) {
        navigate(`/formation/${data.token}`);
      } else {
        throw new Error(data.error || "Erreur lors de la génération de l'accès");
      }
    } catch (err: any) {
      console.error("Resume error:", err);
      setStatusMessage({ type: "error", text: err.message });
      setTimeout(() => setStatusMessage(null), 5000);
    } finally {
      setResumeLoading(null);
    }
  };

  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-ngt-black">
        <Loader2 className="animate-spin text-ngt-gold" size={48} />
      </div>
    );
  }

  const formations = [
    {
      id: "psychology",
      productId: "psychology",
      title: "Psychologie du Trading",
      icon: <Brain size={24} />,
      access: profile?.hasAccessPsychology,
      link: "/formation-psychologie",
      desc: "Maîtrisez votre esprit avant de maîtriser les graphiques."
    },
    {
      id: "cameleon",
      productId: "cameleon",
      title: "Plan Caméléon",
      icon: <Target size={24} />,
      access: profile?.hasAccessCameleon,
      link: "/formation-cameleon",
      desc: "La stratégie Sniper sans indicateur pour dominer le marché."
    },
    {
      id: "algo",
      productId: "algo_lifetime",
      title: "Algorithme Caméléon",
      icon: <Cpu size={24} />,
      access: profile?.hasAccessAlgo || profile?.isAlgoUser,
      link: "/cameleon-algo",
      desc: "L'outil de précision institutionnelle pour vos trades."
    }
  ];

  return (
    <div className="min-h-screen bg-ngt-black pt-32 pb-20 px-6">
      <div className="max-w-7xl mx-auto">
        {/* Status Messages */}
        {statusMessage && (
          <motion.div 
            initial={{ opacity: 0, y: -20 }}
            animate={{ opacity: 1, y: 0 }}
            className={`mb-8 p-4 rounded-lg flex items-center gap-3 ${
              statusMessage.type === "success" ? "bg-green-500/10 text-green-500 border border-green-500/20" : "bg-red-500/10 text-red-500 border border-red-500/20"
            }`}
          >
            <span className="text-xs font-bold uppercase tracking-widest">{statusMessage.text}</span>
          </motion.div>
        )}

        {/* Header */}
        <div className="flex flex-col md:flex-row justify-between items-start md:items-center mb-16 gap-8">
          <div>
            <span className="text-xs uppercase tracking-[0.4em] text-ngt-gold mb-2 block">
              {profile?.isSniper ? "Statut Sniper Activé" : "Bienvenue Sniper"}
            </span>
            <h1 className="text-4xl md:text-5xl font-serif italic gold-text">
              {profile?.isSniper && profile?.matricule ? profile.matricule : (user?.displayName || user?.email?.split('@')[0] || "Membre")}
            </h1>
            {isAdmin && (
              <span className="inline-block mt-2 px-3 py-1 bg-ngt-gold text-ngt-black text-[10px] font-bold uppercase tracking-widest rounded-full">
                Administrateur
              </span>
            )}
          </div>
          <button 
            onClick={handleLogout}
            className="flex items-center gap-2 text-ngt-white/40 hover:text-red-500 transition-colors text-xs uppercase tracking-widest"
          >
            <LogOut size={16} /> Se déconnecter
          </button>
        </div>

        {/* Sniper Exclusive Section */}
        {profile?.isSniper && (
          <motion.div 
            initial={{ opacity: 0, y: 20 }}
            animate={{ opacity: 1, y: 0 }}
            className="mb-12 p-8 border border-ngt-gold/30 bg-ngt-gold/[0.03] relative overflow-hidden group"
          >
            <div className="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-20 transition-opacity">
              <Target size={120} className="text-ngt-gold" />
            </div>
            
            <div className="relative z-10">
              <h2 className="text-2xl font-serif italic gold-text mb-6">Accès Exclusifs Sniper</h2>
              <div className="grid md:grid-cols-2 gap-6">
                <a 
                  href={profile.whatsappLink || "#"} 
                  target="_blank" 
                  rel="noopener noreferrer"
                  className="flex items-center gap-4 p-6 bg-ngt-black border border-ngt-white/10 hover:border-ngt-gold transition-colors group"
                >
                  <div className="w-12 h-12 rounded-full bg-green-500/10 flex items-center justify-center text-green-500">
                    <svg viewBox="0 0 24 24" width="24" height="24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.634 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </div>
                <div>
                  <div className="text-xs uppercase tracking-widest text-ngt-white/30 mb-1">Groupe WhatsApp</div>
                  <div className="text-sm font-bold group-hover:text-ngt-gold transition-colors">Rejoindre la Communauté</div>
                </div>
              </a>

              <a 
                href={profile.zoomLink || "#"} 
                target="_blank" 
                rel="noopener noreferrer"
                className="flex items-center gap-4 p-6 bg-ngt-black border border-ngt-white/10 hover:border-ngt-gold transition-colors group"
              >
                <div className="w-12 h-12 rounded-full bg-blue-500/10 flex items-center justify-center text-blue-500">
                  <Play size={24} />
                </div>
                <div>
                  <div className="text-xs uppercase tracking-widest text-ngt-white/30 mb-1">Sessions Zoom Live</div>
                  <div className="text-sm font-bold group-hover:text-ngt-gold transition-colors">Accéder aux Lives</div>
                </div>
              </a>
            </div>
          </div>
        </motion.div>
      )}

      {/* Dashboard Grid */}
      <div className="grid lg:grid-cols-3 gap-8">
        {/* Main Content */}
        <div className="lg:col-span-2 space-y-8">
          <h2 className="text-xl font-serif mb-6 border-b border-ngt-white/10 pb-4">Vos Formations</h2>
          
          <div className="grid gap-6">
            {formations.map((f) => (
              <motion.div 
                key={f.id}
                whileHover={f.access ? { x: 10 } : {}}
                className={`p-8 border transition-all duration-500 flex flex-col md:flex-row items-center justify-between gap-8 ${
                  f.access 
                    ? "border-ngt-gold/30 bg-ngt-gold/[0.02] hover:bg-ngt-gold/[0.05]" 
                    : "border-ngt-white/5 bg-ngt-white/[0.01] opacity-60"
                }`}
              >
                <div className="flex items-center gap-6">
                  <div className={`w-16 h-16 rounded-full flex items-center justify-center ${f.access ? "bg-ngt-gold/10 text-ngt-gold" : "bg-ngt-white/5 text-ngt-white/20"}`}>
                    {f.icon}
                  </div>
                  <div>
                    <h3 className="text-xl font-serif mb-2">{f.title}</h3>
                    <p className="text-sm text-ngt-white/40 max-w-sm">{f.desc}</p>
                  </div>
                </div>

                {f.access ? (
                  <button 
                    onClick={() => handleResume(f.productId)}
                    disabled={resumeLoading !== null}
                    className="px-8 py-3 bg-ngt-gold text-ngt-black text-[10px] uppercase tracking-widest font-bold gold-gradient flex items-center gap-2 hover:scale-[1.02] transition-transform disabled:opacity-50"
                  >
                    {resumeLoading === f.productId ? (
                      <Loader2 size={14} className="animate-spin" />
                    ) : (
                      <Play size={14} fill="currentColor" />
                    )}
                    {resumeLoading === f.productId ? "Chargement..." : "Reprendre"}
                  </button>
                ) : (
                  <Link 
                    to={f.link}
                    className="flex items-center gap-2 text-ngt-white/20 text-[10px] uppercase tracking-widest font-bold border border-ngt-white/10 px-6 py-3 hover:border-ngt-gold hover:text-ngt-gold transition-colors"
                  >
                    <Lock size={14} /> Déverrouiller
                  </Link>
                )}
              </motion.div>
            ))}
          </div>
        </div>

          {/* Sidebar */}
          <div className="space-y-8">
            {isAdmin && (
              <div className="p-8 border border-ngt-gold bg-ngt-gold/5">
                <div className="flex items-center gap-3 mb-6">
                  <Target className="text-ngt-gold" size={20} />
                  <h2 className="text-lg font-serif">Administration</h2>
                </div>
                <p className="text-sm text-ngt-white/50 mb-6">
                  Accédez aux outils de gestion et aux logs de paiement.
                </p>
                <Link 
                  to="/admin"
                  className="px-6 py-3 bg-ngt-gold text-ngt-black text-[10px] uppercase tracking-widest font-bold gold-gradient flex items-center justify-center gap-2"
                >
                  Dashboard Admin
                </Link>
              </div>
            )}

            <div className="p-8 border border-ngt-white/10 bg-ngt-white/[0.02]">
              <div className="flex items-center gap-3 mb-6">
                <UserIcon className="text-ngt-gold" size={20} />
                <h2 className="text-lg font-serif">Votre Profil</h2>
              </div>
              <div className="space-y-4">
                <div>
                  <span className="text-[10px] uppercase tracking-widest text-ngt-white/30 block mb-1">Email</span>
                  <span className="text-sm text-ngt-white/70">{user?.email}</span>
                </div>
                <div>
                  <span className="text-[10px] uppercase tracking-widest text-ngt-white/30 block mb-1">Statut</span>
                  <span className="text-xs text-ngt-gold bg-ngt-gold/10 px-2 py-1 rounded">Membre Actif</span>
                </div>
              </div>
            </div>

            <div className="p-8 border border-ngt-gold/20 bg-ngt-gold/[0.02]">
              <h3 className="text-lg font-serif mb-4">Besoin d'aide ?</h3>
              <p className="text-sm text-ngt-white/50 mb-6">
                Une question sur votre accès ou un problème technique ?
              </p>
              <Link 
                to="/support"
                className="text-ngt-gold text-[10px] uppercase tracking-widest font-bold flex items-center gap-2 group"
              >
                Contacter le support <ChevronRight size={14} className="group-hover:translate-x-1 transition-transform" />
              </Link>
            </div>
          </div>
        </div>
      </div>
    </div>
  );
}
