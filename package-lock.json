import { psychologyTestQuestions } from "../data/psychologyTestQuestions";

export interface TestResultData {
  score: number;
  level: "solide" | "modere" | "critique";
  recommendation: string;
  ctaLink: string;
  ctaText: string;
}

export const calculateScore = (answers: Record<number, number>): number => {
  let totalPoints = 0;
  let maxPossiblePoints = 0;

  psychologyTestQuestions.forEach((q) => {
    const selectedOptionIndex = answers[q.id];
    if (selectedOptionIndex !== undefined) {
      totalPoints += q.options[selectedOptionIndex].points;
    }
    
    // Calculate max possible points for this question
    const maxPointsForQ = Math.max(...q.options.map(o => o.points));
    maxPossiblePoints += maxPointsForQ;
  });

  if (maxPossiblePoints === 0) return 0;
  return Math.round((totalPoints / maxPossiblePoints) * 100);
};

export const getResultData = (score: number): TestResultData => {
  if (score <= 30) {
    return {
      score,
      level: "solide",
      recommendation: "Vous avez une base psychologique solide. Votre discipline est votre plus grand atout. Pour passer au niveau supérieur, concentrez-vous sur l'optimisation de vos entrées avec nos outils gratuits.",
      ctaLink: "/#products",
      ctaText: "Découvrir nos ressources"
    };
  } else if (score <= 60) {
    return {
      score,
      level: "modere",
      recommendation: "Votre psychologie est modérément affectée par le marché. Vous avez des bases, mais vos émotions prennent parfois le dessus, ce qui freine votre rentabilité. Le Plan Caméléon est conçu exactement pour stabiliser votre trading et éliminer vos doutes.",
      ctaLink: "/checkout?productId=cameleon",
      ctaText: "Stabiliser mon trading"
    };
  } else {
    return {
      score,
      level: "critique",
      recommendation: "ALERTE : Votre psychologie est en zone critique. Le marché a pris le contrôle de vos émotions, ce qui met votre capital en grand danger. Vous avez besoin d'un cadre strict et d'outils automatisés pour supprimer le facteur humain. Le Full Pack NGT est votre meilleure chance de survie et de succès.",
      ctaLink: "/checkout?productId=cameleon",
      ctaText: "Sauver mon capital"
    };
  }
};
