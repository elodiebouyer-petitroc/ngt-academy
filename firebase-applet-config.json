import React, { useState } from "react";
import { motion, AnimatePresence } from "framer-motion";
import { psychologyTestQuestions } from "../data/psychologyTestQuestions";
import { useTestProgress } from "../hooks/useTestProgress";
import { calculateScore, getResultData } from "../utils/testScoring";
import TestQuestion from "../components/TestQuestion";
import TestResult from "../components/TestResult";
import { Brain, ArrowRight, Mail, Loader2, ChevronLeft } from "lucide-react";
import { db } from "../firebase";
import { collection, addDoc, serverTimestamp } from "firebase/firestore";

export default function TradingPsychologyTest() {
  const { 
    currentStep, 
    answers, 
    email, 
    handleAnswer, 
    completeTest, 
    prevStep, 
    nextStep,
    restart 
  } = useTestProgress();

  const [emailInput, setEmailInput] = useState("");
  const [isSubmitting, setIsSubmitting] = useState(false);

  const totalQuestions = psychologyTestQuestions.length;
  const isIntro = currentStep === 0;
  const isQuestion = currentStep > 0 && currentStep <= totalQuestions;
  const isEmailStep = currentStep === totalQuestions + 1;
  const isResult = currentStep === totalQuestions + 2;

  const handleEmailSubmit = async (e: React.FormEvent) => {
    e.preventDefault();
    if (!emailInput) return;

    setIsSubmitting(true);
    const score = calculateScore(answers);
    const resultData = getResultData(score);

    try {
      // Save lead to Firestore
      await addDoc(collection(db, "test_leads"), {
        email: emailInput.toLowerCase().trim(),
        score,
        level: resultData.level,
        timestamp: serverTimestamp(),
        source: "psychology_test"
      });
      
      completeTest(emailInput);
    } catch (err) {
      console.error("Error saving lead:", err);
      // Still show result even if save fails
      completeTest(emailInput);
    } finally {
      setIsSubmitting(false);
    }
  };

  return (
    <div className="min-h-screen bg-ngt-black pt-32 pb-24 px-6 relative overflow-hidden">
      {/* Background Elements */}
      <div className="absolute inset-0 z-0 pointer-events-none">
        <div className="absolute top-1/4 left-1/4 w-[500px] h-[500px] bg-ngt-gold/5 rounded-full blur-[120px]" />
        <div className="absolute bottom-1/4 right-1/4 w-[400px] h-[400px] bg-ngt-gold/3 rounded-full blur-[100px]" />
      </div>

      <div className="max-w-4xl mx-auto relative z-10">
        <AnimatePresence mode="wait">
          {isIntro && (
            <motion.div
              key="intro"
              initial={{ opacity: 0, y: 20 }}
              animate={{ opacity: 1, y: 0 }}
              exit={{ opacity: 0, y: -20 }}
              className="text-center"
            >
              <div className="mb-8 inline-flex p-4 rounded-full bg-ngt-gold/10 text-ngt-gold">
                <Brain size={48} />
              </div>
              <h1 className="text-4xl md:text-6xl font-serif italic mb-6 gold-text">
                Diagnostic Psychologique du Trader
              </h1>
              <p className="text-ngt-white/50 text-lg mb-12 max-w-2xl mx-auto leading-relaxed">
                Le trading est à 90% psychologique. Découvrez votre niveau d'affectation émotionnelle et obtenez un diagnostic personnalisé pour stabiliser vos performances.
              </p>
              
              <div className="grid md:grid-cols-3 gap-6 mb-12 text-left">
                {[
                  { title: "20 Questions", desc: "Un test complet sur vos habitudes." },
                  { title: "Analyse IA", desc: "Un diagnostic précis de vos blocages." },
                  { title: "Plan d'action", desc: "Des solutions concrètes pour progresser." }
                ].map((item, i) => (
                  <div key={i} className="p-6 border border-ngt-white/10 bg-ngt-white/[0.02]">
                    <h3 className="text-ngt-gold text-[10px] uppercase tracking-widest font-bold mb-2">{item.title}</h3>
                    <p className="text-ngt-white/40 text-xs">{item.desc}</p>
                  </div>
                ))}
              </div>

              <button
                onClick={nextStep}
                className="px-12 py-5 bg-ngt-gold text-ngt-black text-[10px] uppercase tracking-widest font-bold gold-gradient hover:scale-[1.05] transition-transform flex items-center gap-3 mx-auto"
              >
                Démarrer le test <ArrowRight size={16} />
              </button>
            </motion.div>
          )}

          {isQuestion && (
            <div key="question-container">
              <button 
                onClick={prevStep}
                className="mb-8 flex items-center gap-2 text-[10px] uppercase tracking-widest text-ngt-white/30 hover:text-ngt-gold transition-colors"
              >
                <ChevronLeft size={14} /> Retour
              </button>
              <TestQuestion
                question={psychologyTestQuestions[currentStep - 1]}
                totalQuestions={totalQuestions}
                currentIndex={currentStep - 1}
                onAnswer={(idx) => handleAnswer(psychologyTestQuestions[currentStep - 1].id, idx)}
              />
            </div>
          )}

          {isEmailStep && (
            <motion.div
              key="email-step"
              initial={{ opacity: 0, scale: 0.95 }}
              animate={{ opacity: 1, scale: 1 }}
              className="max-w-md mx-auto text-center"
            >
              <div className="mb-8 inline-flex p-4 rounded-full bg-ngt-gold/10 text-ngt-gold">
                <Mail size={32} />
              </div>
              <h2 className="text-3xl font-serif italic mb-4 gold-text">Analyse terminée !</h2>
              <p className="text-ngt-white/50 text-sm mb-10">
                Entrez votre email pour recevoir votre diagnostic complet et découvrir votre score d'affectation psychologique.
              </p>

              <form onSubmit={handleEmailSubmit} className="space-y-4">
                <div className="relative">
                  <Mail className="absolute left-4 top-1/2 -translate-y-1/2 text-ngt-gold/50" size={18} />
                  <input
                    type="email"
                    required
                    value={emailInput}
                    onChange={(e) => setEmailInput(e.target.value)}
                    placeholder="votre@email.com"
                    className="w-full bg-ngt-white/5 border border-ngt-white/10 py-4 pl-12 pr-4 text-sm focus:border-ngt-gold outline-none transition-colors text-ngt-white"
                  />
                </div>
                <button
                  type="submit"
                  disabled={isSubmitting}
                  className="w-full py-4 bg-ngt-gold text-ngt-black text-[10px] uppercase tracking-widest font-bold gold-gradient flex items-center justify-center gap-2 hover:scale-[1.02] transition-transform disabled:opacity-50"
                >
                  {isSubmitting ? (
                    <Loader2 className="animate-spin" size={16} />
                  ) : (
                    <>Voir mes résultats <ArrowRight size={14} /></>
                  )}
                </button>
              </form>
              <p className="mt-6 text-[8px] uppercase tracking-widest text-ngt-white/20">
                En validant, vous acceptez de recevoir nos conseils de trading par email.
              </p>
            </motion.div>
          )}

          {isResult && (
            <motion.div
              key="result-container"
              initial={{ opacity: 0 }}
              animate={{ opacity: 1 }}
              exit={{ opacity: 0 }}
            >
              <TestResult 
                result={getResultData(calculateScore(answers))} 
                onRestart={restart}
              />
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </div>
  );
}
